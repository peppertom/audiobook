# ── Database ─────────────────────────────────────────────────────────────────
# Railway managed PostgreSQL (asyncpg driver required)
AUDIOBOOK_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/railway

# ── Redis (Upstash TLS) ───────────────────────────────────────────────────────
# Note: rediss:// (with double 's') for TLS connections
AUDIOBOOK_REDIS_URL=rediss://default:password@host.upstash.io:6380

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUDIOBOOK_JWT_SECRET=change-me-to-a-random-64-char-string

# ── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed frontend origins
AUDIOBOOK_CORS_ORIGINS=["https://your-app.vercel.app"]

# ── Cloudflare R2 Storage ─────────────────────────────────────────────────────
# R2 endpoint: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://abc123.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=audiobook
# Public bucket URL (enable public access in R2 dashboard)
R2_PUBLIC_URL=https://pub-abc123.r2.dev

# ── LLM / Annotator ──────────────────────────────────────────────────────────
# Ollama-compatible endpoint (RunPod or Together.ai OpenAI-compatible URL)
AUDIOBOOK_OLLAMA_BASE_URL=http://localhost:11434

# ── Optional ─────────────────────────────────────────────────────────────────
AUDIOBOOK_FREE_SIGNUP_CREDITS=3
